# SPDX-License-Identifier: Apache-2.0
#
# Copyright (c) 2023 Intercreate, Inc.
# Author: J.P. Hutchins <jp@intercreate.io>
#
# J.P.'s Python(black)-inspired .clang-format for C repositories.
#
# Requires clang-format 22
#
# Includes Zephyr and Arm macro compatibility
#
# black-isms worth knowing:
#   - When any (), {}, parameter or argument list breaks, every element goes on
#     its own line and the closing bracket sits on its own line (BlockIndent).
#   - Magic trailing comma: a trailing comma in a {} list forces it to explode
#     one-per-line; remove it to let a short list collapse.
#   - Assignments hug the call: `x = f(` stays together and the args break.
#   - Wrap a long ternary/expression in ( ) for the black-style multi-line
#     layout; clang-format keeps your parentheses but will not add them.
#   - for-headers and statement-expression macros are the two things it cannot
#     lay out this way; guard those with clang-format off/on if it matters.
#

---
BasedOnStyle: Google

# clang-format 22 deprecated AlignAfterOpenBracket: BlockIndent and split it
# into a bool plus per-construct Break options. Enabling all of them gives the
# same block-indent to calls, parameters, initializers, if, switch, AND
# for/while headers: the open bracket breaks, items indent, the close bracket
# lands on its own line. (Loop/Switch are NOT auto-enabled by the old value.)
AlignAfterOpenBracket: true
BreakAfterOpenBracketBracedList: true
BreakAfterOpenBracketFunction: true
BreakAfterOpenBracketIf: true
BreakAfterOpenBracketLoop: true
BreakAfterOpenBracketSwitch: true
BreakBeforeCloseBracketBracedList: true
BreakBeforeCloseBracketFunction: true
BreakBeforeCloseBracketIf: true
BreakBeforeCloseBracketLoop: true
BreakBeforeCloseBracketSwitch: true
AlignEscapedNewlines: DontAlign
# DontAlign: never column-align operands - column formatting is not wanted.
# (clang-format still aligns multi-line ternaries and bare parenthesized
# expressions regardless of this; those constructs need an off/on guard.)
AlignOperands: DontAlign
AlignTrailingComments:
  Kind: Never
  OverEmptyLines: 0
# false: once an argument / parameter list wraps, every item gets its own line
# (rustfmt-style) instead of being packed onto one continuation line.
AllowAllArgumentsOnNextLine: false
AllowAllParametersOfDeclarationOnNextLine: false
AllowShortBlocksOnASingleLine: Never
AllowShortCaseExpressionOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false
AllowShortEnumsOnASingleLine: true
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AttributeMacros:
  - __aligned
  - __deprecated
  - __packed
  - __printf_like
  - __syscall
  - __syscall_always_inline
  - __subsystem
BinPackArguments: false
BinPackParameters: false
BraceWrapping:
  AfterCaseLabel: false
  AfterClass: false
  AfterControlStatement: false
  AfterEnum: false
  AfterFunction: false
  AfterNamespace: false
  AfterObjCDeclaration: false
  AfterStruct: false
  AfterUnion: false
  AfterExternBlock: false
  BeforeCatch: false
  BeforeElse: false
  IndentBraces: false
  SplitEmptyFunction: false
  SplitEmptyRecord: false
  SplitEmptyNamespace: false
  BeforeLambdaBody: false
  BeforeWhile: false
BitFieldColonSpacing: After
BreakBeforeBinaryOperators: NonAssignment
BreakBeforeTernaryOperators: false
BreakBeforeBraces: Custom
BreakStringLiterals: true
ColumnLimit: 100
Cpp11BracedListStyle: true
DerivePointerAlignment: false
ForEachMacros:
  - 'FOR_EACH'
  - 'FOR_EACH_FIXED_ARG'
  - 'FOR_EACH_IDX'
  - 'FOR_EACH_IDX_FIXED_ARG'
  - 'FOR_EACH_NONEMPTY_TERM'
  - 'RB_FOR_EACH'
  - 'RB_FOR_EACH_CONTAINER'
  - 'SYS_DLIST_FOR_EACH_CONTAINER'
  - 'SYS_DLIST_FOR_EACH_CONTAINER_SAFE'
  - 'SYS_DLIST_FOR_EACH_NODE'
  - 'SYS_DLIST_FOR_EACH_NODE_SAFE'
  - 'SYS_SFLIST_FOR_EACH_CONTAINER'
  - 'SYS_SFLIST_FOR_EACH_CONTAINER_SAFE'
  - 'SYS_SFLIST_FOR_EACH_NODE'
  - 'SYS_SFLIST_FOR_EACH_NODE_SAFE'
  - 'SYS_SLIST_FOR_EACH_CONTAINER'
  - 'SYS_SLIST_FOR_EACH_CONTAINER_SAFE'
  - 'SYS_SLIST_FOR_EACH_NODE'
  - 'SYS_SLIST_FOR_EACH_NODE_SAFE'
  - '_WAIT_Q_FOR_EACH'
  - 'Z_FOR_EACH'
  - 'Z_FOR_EACH_ENGINE'
  - 'Z_FOR_EACH_EXEC'
  - 'Z_FOR_EACH_FIXED_ARG'
  - 'Z_FOR_EACH_FIXED_ARG_EXEC'
  - 'Z_FOR_EACH_IDX'
  - 'Z_FOR_EACH_IDX_EXEC'
  - 'Z_FOR_EACH_IDX_FIXED_ARG'
  - 'Z_FOR_EACH_IDX_FIXED_ARG_EXEC'
  - 'Z_GENLIST_FOR_EACH_CONTAINER'
  - 'Z_GENLIST_FOR_EACH_CONTAINER_SAFE'
  - 'Z_GENLIST_FOR_EACH_NODE'
  - 'Z_GENLIST_FOR_EACH_NODE_SAFE'
  - 'STRUCT_SECTION_FOREACH'
  - 'TYPE_SECTION_FOREACH'
IfMacros:
  - 'CHECKIF'
IncludeBlocks: Preserve
IndentCaseBlocks: false
IndentCaseLabels: true
IndentWidth: 4
InsertNewlineAtEOF: true
LineEnding: LF
MaxEmptyLinesToKeep: 2
# High penalty makes `x = f(...)` hug the call (break inside the parens)
# instead of breaking after the `=`.
PenaltyBreakAssignment: 300
# High penalty keeps the return type on the function name's line, so a long
# signature wraps its parameters one-per-line rather than the return type.
PenaltyReturnTypeOnItsOwnLine: 1000
PointerAlignment: Middle
# Never reflow comments: clang-format must not rewrap hand-formatted comments.
ReflowComments: Never
SortIncludes: CaseSensitive
# true: a space follows a C-style cast, `(int) x`. It also spaces compound
# literals to `(struct foo) {...}`, which is consistent.
SpaceAfterCStyleCast: true
SpaceBeforeParens: ControlStatementsExceptControlMacros
UseTab: Never
WhitespaceSensitiveMacros:
  - STRINGIFY
  - Z_STRINGIFY
