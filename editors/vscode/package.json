{
  "name": "jphfmt",
  "displayName": "jphfmt — opinionated C formatter",
  "description": "Format C with jphfmt: one uniform bracket rule, no column alignment.",
  "version": "0.1.0",
  "publisher": "JPHutchins",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/JPHutchins/jphfmt.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "jphfmt",
      "properties": {
        "jphfmt.path": {
          "type": "string",
          "default": "jphfmt",
          "description": "Path to the jphfmt executable."
        },
        "jphfmt.width": {
          "type": "number",
          "default": 100,
          "description": "Column limit passed to jphfmt --width."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "bundle": "node bundle.mjs",
    "build": "tsc -p ./ && node bundle.mjs",
    "typecheck": "tsc -p ./ --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.mjs\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \"*.mjs\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "watch": "tsc -p ./ -w"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  }
}
