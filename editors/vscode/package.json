{
  "name": "cfmt",
  "displayName": "cfmt — opinionated C formatter",
  "description": "Format C with cfmt: one uniform bracket rule, no column alignment.",
  "version": "0.1.0",
  "publisher": "intercreate",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:c"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "cfmt",
      "properties": {
        "cfmt.path": {
          "type": "string",
          "default": "cfmt",
          "description": "Path to the cfmt executable."
        },
        "cfmt.width": {
          "type": "number",
          "default": 100,
          "description": "Column limit passed to cfmt --width."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "check": "tsc -p ./ --noEmit",
    "watch": "tsc -p ./ -w"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.6.3"
  }
}
