 /// Whether a `?` ternary operator appears at bracket depth zero in `inner`.
 fn has_top_level_question(inner: &[Token]) -> bool {
     let mut depth = 0i32;
     for t in inner {
         match t.text {
-            "(" | "[" | "{" => depth += 1,
+            "(" | "[" | "{" => depth -= /* ~ changed by cargo-mutants ~ */ 1,
             ")" | "]" | "}" => depth -= 1,
             "?" if depth == 0 && t.kind == TokenKind::Punct => return true,
             _ => {}
         }
     }
