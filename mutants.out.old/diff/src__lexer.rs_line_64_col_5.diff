 /// Extend a `//` match to just before the line's end (the newline stays its own token).
 fn lex_line_comment(lex: &mut Lexer<TokenKind>) {
     let rem = lex.remainder();
     lex.bump(rem.find(['\n', '\r']).unwrap_or(rem.len()));
 }
 
